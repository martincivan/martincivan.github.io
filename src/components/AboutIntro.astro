---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<div class="grid items-start gap-8 md:grid-cols-[1fr_auto] md:gap-12">
  <div class="max-w-2xl space-y-4 text-muted">
    {t.about.bio.map((para) => <p class="leading-relaxed">{para}</p>)}
    <p class="border-l-2 border-accent/50 pl-4 text-sm leading-relaxed text-faint">{t.about.beyond}</p>
  </div>

  <figure class="order-first mx-auto w-44 shrink-0 sm:w-52 md:order-last md:mx-0">
    <div class="relative">
      <span class="pointer-events-none absolute -inset-3 -z-10 rounded-3xl opacity-60 blur-2xl" style="background: radial-gradient(60% 60% at 50% 30%, color-mix(in oklab, var(--color-accent) 35%, transparent), transparent 70%)" aria-hidden="true"></span>
      <img
        src="/photo/martin.jpg"
        alt="Martin Civáň"
        width="700"
        height="934"
        loading="lazy"
        decoding="async"
        class="w-full rounded-2xl border border-border object-cover shadow-xl shadow-black/40"
      />
    </div>
  </figure>
</div>
