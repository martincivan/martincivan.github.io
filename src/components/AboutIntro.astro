---
import { Icon } from 'astro-icon/components';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { iconTone } from '../data/techIcons';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const pillars = t.home.pillars;
---
<div class="space-y-14">
  <div class="max-w-3xl space-y-4 text-[--color-muted]">
    {t.about.bio.map((para) => <p class="leading-relaxed">{para}</p>)}
    <p class="border-l-2 border-[--color-border] pl-4 text-sm leading-relaxed text-[--color-faint]">{t.about.beyond}</p>
  </div>

  <div>
    <p class="mb-5 font-mono text-xs uppercase tracking-wider text-[--color-faint]">{t.sections.whatIDo}</p>
    <div class="grid gap-4 lg:grid-cols-3">
      {pillars.map((p) => (
        <article class="pillar flex flex-col rounded-xl border border-[--color-border] bg-[--color-surface]/40 p-5 transition-colors hover:border-[color:color-mix(in_oklab,var(--color-accent)_45%,transparent)]">
          <p class="font-mono text-[11px] uppercase tracking-wider text-[--color-accent]">{p.tag}</p>
          <h3 class="mt-1.5 text-base font-semibold text-[--color-fg]">{p.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-[--color-muted]">{p.body}</p>

          <div class="mt-auto pt-6">
            <ul class="flex flex-wrap items-center gap-2">
              {p.tech.map((tech, ti) => (
                <li class="tech group/tech relative h-7 w-7" style={`--d:${ti * 45}ms`}>
                  <span class="tech-chip absolute left-0 top-0 inline-flex h-7 items-center overflow-hidden rounded-md border border-[--color-border]">
                    <span class:list={["tech-icon flex h-7 w-7 shrink-0 items-center justify-center", `is-${iconTone(tech.icon)}`]}>
                      <Icon name={tech.icon} class="h-[18px] w-[18px]" />
                    </span>
                    <span class="tech-name max-w-0 whitespace-nowrap font-mono text-[11px] text-[--color-fg] opacity-0">{tech.name}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>

<style>
  /* Rich logos keep their inner structure at rest (greyscale + lifted brightness so even
     darker brand colours read on the dark background) and bloom to full colour on hover.
     Flat/monochrome logos have no inner colour detail, so they render as a light silhouette
     (brightness(0) flattens to black, invert() lifts it to grey) and just brighten on hover. */
  .tech-icon {
    opacity: 0.9;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .tech-icon.is-rich {
    filter: grayscale(1) brightness(1.4);
  }
  .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.72);
  }
  .group\/tech:hover .tech-icon {
    opacity: 1;
  }
  .group\/tech:hover .tech-icon.is-rich {
    filter: none;
  }
  .group\/tech:hover .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.92);
  }

  /* The name stays collapsed, then slides open beside the icon on hover. The chip is
     absolutely positioned, so it expands over its neighbours instead of reflowing the
     row — this avoids the hovered item wrapping out from under the cursor. */
  .tech-chip {
    z-index: 1;
    /* Opaque fill so the expanded name is never see-through over neighbouring icons. */
    background-color: var(--color-surface);
    transition: border-color 0.2s ease;
  }
  .group\/tech:hover .tech-chip {
    z-index: 10;
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    box-shadow: 0 4px 14px -4px rgb(0 0 0 / 0.6);
  }
  .tech-name {
    transition: max-width 0.24s ease, opacity 0.22s ease, padding 0.24s ease;
  }
  .group\/tech:hover .tech-name {
    max-width: 11rem;
    opacity: 1;
    padding: 0 0.5rem 0 0.25rem;
  }

  /* Staggered reveal once the card scrolls into view. */
  .tech {
    opacity: 0;
    transform: translateY(8px);
  }
  .pillar.in-view .tech {
    opacity: 1;
    transform: none;
    transition: opacity 0.45s ease var(--d), transform 0.45s ease var(--d);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech { opacity: 1; transform: none; }
    .pillar.in-view .tech { transition: none; }
    .tech-name { transition: opacity 0.15s ease; }
  }
</style>

<script>
  const cards = document.querySelectorAll('.pillar');
  if (cards.length) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.25 });
    cards.forEach((c) => io.observe(c));
  }
</script>
