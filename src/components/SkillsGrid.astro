---
import { Icon } from 'astro-icon/components';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { getLanguages, getEducation } from '../data/localized';
import { iconTone } from '../data/techIcons';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const pillars = t.home.pillars;
const languages = getLanguages(lang);
const education = getEducation(lang);

// Visual identity per pillar (same order in both locales).
const pillarMeta = [
  { icon: 'lucide:server',     accent: '#818cf8' },
  { icon: 'lucide:blocks',     accent: '#c084fc' },
  { icon: 'lucide:brain-circuit', accent: '#22d3ee' },
];
---
<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
  {pillars.map((p, pi) => (
    <div class="tech-pool card relative overflow-hidden p-5" style={`--p:${pillarMeta[pi]?.accent ?? 'var(--color-accent)'}`}>
      <div class="flex items-center gap-3">
        <span class="icon-tile h-9 w-9 shrink-0" aria-hidden="true">
          <Icon name={pillarMeta[pi]?.icon ?? 'lucide:layers'} class="h-[18px] w-[18px]" />
        </span>
        <h3 class="font-mono text-xs font-medium uppercase tracking-wider" style={`color:${pillarMeta[pi]?.accent ?? 'var(--color-accent)'}`}>{p.tag}</h3>
      </div>
      <ul class="mt-4 flex flex-wrap items-center gap-2">
        {p.tech.map((tech, ti) => (
          <li class="tech group/tech relative h-7 w-7" style={`--d:${ti * 45}ms`}>
            <span class="tech-chip absolute left-0 top-0 inline-flex h-7 items-center overflow-hidden rounded-md border border-border">
              <span class:list={["tech-icon flex h-7 w-7 shrink-0 items-center justify-center", `is-${iconTone(tech.icon)}`]}>
                <Icon name={tech.icon} class="h-[18px] w-[18px]" />
              </span>
              <span class="tech-name max-w-0 whitespace-nowrap font-mono text-[11px] text-fg opacity-0">{tech.name}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>

<div class="mt-12 grid gap-10 border-t border-border pt-10 md:grid-cols-2">
  <div>
    <h3 class="font-mono text-xs uppercase tracking-wider text-faint">{t.about.education}</h3>
    <div class="mt-4 space-y-5">
      {education.map((e) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h4 class="font-semibold">{e.school}</h4>
            <span class="font-mono text-xs text-faint">{e.period}</span>
          </div>
          <p class="mt-1 text-sm text-accent">{e.program}</p>
          {e.note && <p class="mt-2 text-sm leading-relaxed text-muted">{e.note}</p>}
        </div>
      ))}
    </div>
  </div>
  <div>
    <h3 class="font-mono text-xs uppercase tracking-wider text-faint">{t.about.languagesTitle}</h3>
    <ul class="mt-4 space-y-3">
      {languages.map((l) => (
        <li class="flex items-baseline justify-between border-b border-border pb-2">
          <span class="font-medium">{l.lang}</span>
          <span class="font-mono text-xs text-muted">{l.level}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  /* Rich logos keep their inner structure at rest (greyscale + lifted brightness so even
     darker brand colours read on the dark background) and bloom to full colour on hover.
     Flat/monochrome logos render as a light silhouette and just brighten on hover. */
  .tech-icon {
    opacity: 0.9;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .tech-icon.is-rich {
    filter: grayscale(1) brightness(1.4);
  }
  .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.72);
  }
  .group\/tech:hover .tech-icon {
    opacity: 1;
  }
  .group\/tech:hover .tech-icon.is-rich {
    filter: none;
  }
  .group\/tech:hover .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.92);
  }

  /* The chip is absolutely positioned, so the name expands over its neighbours on hover
     instead of reflowing the row (which would wrap the hovered item out from under the cursor). */
  .tech-chip {
    z-index: 1;
    background-color: var(--color-surface);
    transition: border-color 0.2s ease;
  }
  .group\/tech:hover .tech-chip {
    z-index: 10;
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    box-shadow: 0 4px 14px -4px rgb(0 0 0 / 0.6);
  }
  .tech-name {
    transition: max-width 0.24s ease, opacity 0.22s ease, padding 0.24s ease;
  }
  .group\/tech:hover .tech-name {
    max-width: 11rem;
    opacity: 1;
    padding: 0 0.5rem 0 0.25rem;
  }

  /* Staggered reveal once the pool scrolls into view. */
  .tech {
    opacity: 0;
    transform: translateY(8px);
  }
  .tech-pool.in-view .tech {
    opacity: 1;
    transform: none;
    transition: opacity 0.45s ease var(--d), transform 0.45s ease var(--d);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech { opacity: 1; transform: none; }
    .tech-pool.in-view .tech { transition: none; }
    .tech-name { transition: opacity 0.15s ease; }
  }
</style>

<script>
  const pools = document.querySelectorAll('.tech-pool');
  if (pools.length) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.2 });
    pools.forEach((p) => io.observe(p));
  }
</script>
