---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { getExperience, getLanguages, getEducation } from '../data/localized';
import { skills } from '../data/skills';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const a = t.about;
const experience = getExperience(lang);
const languages = getLanguages(lang);
const education = getEducation(lang);
const groupLabel = (label: string) => t.skillGroups[label] ?? label;
---
<!-- Intro -->
<section class="py-16">
  <p class="font-mono text-sm text-[--color-accent]">{a.kicker}</p>
  <h1 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">{a.h1}</h1>
  <div class="mt-6 max-w-2xl space-y-4 text-[--color-muted]">
    {a.bio.map((para) => <p>{para}</p>)}
  </div>
  <div class="mt-8 flex flex-wrap gap-3">
    <a href="https://github.com/martincivan" target="_blank" rel="noopener" class="rounded-lg bg-[--color-accent-strong] px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[--color-accent]">GitHub</a>
    <a href="https://www.linkedin.com/in/martincivan" target="_blank" rel="noopener" class="rounded-lg border border-[--color-border] px-5 py-2.5 text-sm font-medium transition-colors hover:bg-[--color-surface]">LinkedIn</a>
    <a href="mailto:martin.civan5@gmail.com" class="rounded-lg border border-[--color-border] px-5 py-2.5 text-sm font-medium transition-colors hover:bg-[--color-surface]">Email</a>
  </div>
</section>

<!-- Experience -->
<section class="py-12">
  <h2 class="text-2xl font-semibold tracking-tight">{a.experience}</h2>
  <div class="mt-8 space-y-10">
    {experience.map((role) => (
      <article class="border-l border-[--color-border] pl-6 sm:pl-8">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
          <h3 class="text-lg font-semibold">
            {role.title}<span class="text-[--color-muted]"> · </span>
            {role.href ? (
              <a href={role.href} target="_blank" rel="noopener" class="text-[--color-accent] hover:underline">{role.company}</a>
            ) : (
              <span class="text-[--color-accent]">{role.company}</span>
            )}
          </h3>
          <span class="font-mono text-xs text-[--color-faint]">{role.period}</span>
        </div>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[--color-muted]">{role.summary}</p>
        <ul class="mt-4 space-y-2">
          {role.highlights.map((h) => (
            <li class="flex gap-3 text-sm leading-relaxed text-[--color-muted]">
              <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[--color-accent]"></span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
        {role.stack && (
          <ul class="mt-4 flex flex-wrap gap-1.5">
            {role.stack.map((s) => (
              <li class="rounded-md border border-[--color-border] px-2 py-0.5 font-mono text-[11px] text-[--color-faint]">{s}</li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>

<!-- Skills -->
<section class="py-12">
  <h2 class="text-2xl font-semibold tracking-tight">{a.skills}</h2>
  <div class="mt-8 grid gap-5 sm:grid-cols-2">
    {skills.map((g) => (
      <div class="rounded-[--radius-card] border border-[--color-border] bg-[--color-surface]/40 p-5">
        <h3 class="font-mono text-xs uppercase tracking-wider text-[--color-accent]">{groupLabel(g.label)}</h3>
        <ul class="mt-3 flex flex-wrap gap-1.5">
          {g.items.map((i) => (
            <li class="rounded-md bg-[--color-bg-soft] px-2.5 py-1 text-xs text-[--color-fg]">{i}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<!-- Education + Languages -->
<section class="grid gap-10 py-12 md:grid-cols-2">
  <div>
    <h2 class="text-2xl font-semibold tracking-tight">{a.education}</h2>
    <div class="mt-6 space-y-6">
      {education.map((e) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="font-semibold">{e.school}</h3>
            <span class="font-mono text-xs text-[--color-faint]">{e.period}</span>
          </div>
          <p class="mt-1 text-sm text-[--color-accent]">{e.program}</p>
          {e.note && <p class="mt-2 text-sm leading-relaxed text-[--color-muted]">{e.note}</p>}
        </div>
      ))}
    </div>
  </div>
  <div>
    <h2 class="text-2xl font-semibold tracking-tight">{a.languagesTitle}</h2>
    <ul class="mt-6 space-y-3">
      {languages.map((l) => (
        <li class="flex items-baseline justify-between border-b border-[--color-border] pb-2">
          <span class="font-medium">{l.lang}</span>
          <span class="font-mono text-xs text-[--color-muted]">{l.level}</span>
        </li>
      ))}
    </ul>
    <h2 class="mt-10 text-2xl font-semibold tracking-tight">{a.beyondTitle}</h2>
    <p class="mt-4 text-sm leading-relaxed text-[--color-muted]">{a.beyond}</p>
  </div>
</section>
