---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const socials = [
  { href: 'https://github.com/martincivan', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/martincivan', label: 'LinkedIn' },
  { href: 'mailto:martin.civan5@gmail.com', label: 'Email' },
];
---
<footer class="mt-24 border-t border-[--color-border]">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-[--color-muted] sm:flex-row">
    <p>© 2026 Martin Civáň · {t.footer.tagline}</p>
    <ul class="flex gap-5">
      {socials.map((s) => (
        <li>
          <a href={s.href} class="transition-colors hover:text-[--color-fg]" target="_blank" rel="noopener">{s.label}</a>
        </li>
      ))}
    </ul>
  </div>
</footer>
