---
import type { Lang } from '../i18n/utils';
import { localePath } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang).home;
const projectsHref = localePath('/projects/', lang);
const aboutHref = localePath('/about/', lang);
---
<!-- Hero -->
<section class="flex min-h-[78vh] flex-col justify-center py-16">
  <p class="mb-5 font-mono text-sm text-[--color-accent]">{t.kicker}</p>
  <h1 class="max-w-3xl text-4xl font-semibold leading-[1.08] tracking-tight sm:text-6xl">
    {t.h1a}
    <span class="text-gradient">{t.h1accent}</span>
  </h1>
  <p class="mt-7 max-w-2xl text-lg leading-relaxed text-[--color-muted]">{t.lead}</p>
  <div class="mt-10 flex flex-wrap items-center gap-3">
    <a href={projectsHref} class="rounded-lg bg-[--color-accent-strong] px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[--color-accent]">{t.ctaWork}</a>
    <a href={aboutHref} class="rounded-lg border border-[--color-border] px-5 py-2.5 text-sm font-medium text-[--color-fg] transition-colors hover:bg-[--color-surface]">{t.ctaAbout}</a>
  </div>
</section>

<!-- Pillars -->
<section class="py-12">
  <div class="grid gap-5 md:grid-cols-3">
    {t.pillars.map((p) => (
      <article class="rounded-[--radius-card] border border-[--color-border] bg-[--color-surface]/40 p-6 transition-colors hover:border-[--color-accent]/40">
        <p class="font-mono text-xs uppercase tracking-wider text-[--color-accent]">{p.tag}</p>
        <h3 class="mt-3 text-lg font-semibold">{p.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-[--color-muted]">{p.body}</p>
        <ul class="mt-4 flex flex-wrap gap-1.5">
          {p.stack.map((s) => (
            <li class="rounded-md border border-[--color-border] px-2 py-0.5 font-mono text-[11px] text-[--color-faint]">{s}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

<!-- Featured work -->
<section class="py-12">
  <div class="mb-8 flex items-end justify-between">
    <h2 class="text-2xl font-semibold tracking-tight">{t.selectedTitle}</h2>
    <a href={projectsHref} class="font-mono text-sm text-[--color-muted] transition-colors hover:text-[--color-fg]">{t.selectedAll}</a>
  </div>
  <div class="flex flex-col gap-4">
    {t.featured.map((f) => (
      <article class:list={[
        'rounded-[--radius-card] border p-6 transition-colors',
        f.accent ? 'border-[--color-accent]/40 bg-[--color-accent]/[0.04]' : 'border-[--color-border] bg-[--color-surface]/40 hover:border-[--color-accent]/30',
      ]}>
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h3 class="text-lg font-semibold">{f.name}</h3>
          <span class="font-mono text-xs text-[--color-faint]">{f.kind}</span>
        </div>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[--color-muted]">{f.blurb}</p>
        {f.link && (
          <a href={f.link} target="_blank" rel="noopener" class="mt-3 inline-block font-mono text-sm text-[--color-accent] hover:underline">{f.linkLabel}</a>
        )}
      </article>
    ))}
  </div>
</section>
