---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { getProjects, categoryLabel, statusLabel } from '../data/localized';
import type { ProjectCategory } from '../data/projects';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang).projects;
const projects = getProjects(lang);

const order: ProjectCategory[] = ['Platform & Infrastructure', 'Products', 'AI / ML', 'Demos & Experiments'];
const grouped = order
  .map((cat) => ({ cat, items: projects.filter((p) => p.category === cat) }))
  .filter((g) => g.items.length > 0);
---
<section class="py-16">
  <p class="font-mono text-sm text-[--color-accent]">{t.kicker}</p>
  <h1 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">{t.h1}</h1>
  <p class="mt-4 max-w-2xl text-[--color-muted]">{t.intro}</p>
</section>

{grouped.map((group) => (
  <section class="py-8">
    <h2 class="mb-6 font-mono text-sm uppercase tracking-wider text-[--color-muted]">{categoryLabel[lang][group.cat]}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {group.items.map((p) => (
        <article class:list={[
          'flex flex-col rounded-[--radius-card] border p-6 transition-colors',
          p.featured ? 'border-[--color-accent]/40 bg-[--color-accent]/[0.04]' : 'border-[--color-border] bg-[--color-surface]/40 hover:border-[--color-accent]/30',
        ]}>
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-semibold leading-tight">{p.name}</h3>
            {p.status && (
              <span class="shrink-0 rounded-full border border-[--color-border] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-[--color-faint]">{statusLabel[lang][p.status]}</span>
            )}
          </div>
          <p class="mt-1 font-mono text-xs text-[--color-accent]">{p.role} · {p.year}</p>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-[--color-muted]">{p.blurb}</p>
          <ul class="mt-4 flex flex-wrap gap-1.5">
            {p.stack.map((s) => (
              <li class="rounded-md border border-[--color-border] px-2 py-0.5 font-mono text-[11px] text-[--color-faint]">{s}</li>
            ))}
          </ul>
          {p.link && (
            <a href={p.link.href} target={p.link.href.startsWith('/') ? undefined : '_blank'} rel="noopener" class="mt-4 inline-block font-mono text-sm text-[--color-accent] hover:underline">{p.link.label} →</a>
          )}
        </article>
      ))}
    </div>
  </section>
))}
