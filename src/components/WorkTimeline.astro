---
import { Icon } from 'astro-icon/components';
import type { Lang } from '../i18n/utils';
import { getWork, statusLabel } from '../data/localized';
import { techIcons, iconTone } from '../data/techIcons';

interface Props { lang: Lang }
const { lang } = Astro.props;
const work = getWork(lang);
---
<div class="space-y-9">
  {work.map((w) => (
    <article class:list={['relative border-l pl-6 sm:pl-8', w.featured ? 'border-[--color-accent]/40' : 'border-[--color-border]']}>
      <span class:list={['absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full', w.featured ? 'bg-[--color-accent]' : 'bg-[--color-border]']} aria-hidden="true"></span>
      <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
        <h3 class="text-lg font-semibold">
          {w.href ? (
            <a href={w.href} target="_blank" rel="noopener" class="transition-colors hover:text-[--color-accent]">{w.name}</a>
          ) : w.name}
        </h3>
        <div class="flex items-center gap-2">
          {w.status && (
            <span class="rounded-full border border-[--color-border] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-[--color-faint]">{statusLabel[lang][w.status]}</span>
          )}
          <span class="font-mono text-xs text-[--color-faint]">{w.period}</span>
        </div>
      </div>
      <p class="mt-1 font-mono text-xs text-[--color-accent]">{w.kind}</p>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[--color-muted]">{w.summary}</p>
      <ul class="tech-pool mt-4 flex flex-wrap items-center gap-2">
        {w.stack.map((s, si) => (
          techIcons[s] ? (
            <li class="tech group/tech relative h-7 w-7" style={`--d:${si * 45}ms`}>
              <span class="tech-chip absolute left-0 top-0 inline-flex h-7 items-center overflow-hidden rounded-md border border-[--color-border]">
                <span class:list={["tech-icon flex h-7 w-7 shrink-0 items-center justify-center", `is-${iconTone(techIcons[s])}`]}>
                  <Icon name={techIcons[s]} class="h-[18px] w-[18px]" />
                </span>
                <span class="tech-name max-w-0 whitespace-nowrap font-mono text-[11px] text-[--color-fg] opacity-0">{s}</span>
              </span>
            </li>
          ) : (
            <li class="tech inline-flex h-7 items-center rounded-md border border-[--color-border] px-2 font-mono text-[11px] text-[--color-faint]" style={`--d:${si * 45}ms`}>{s}</li>
          )
        ))}
      </ul>
      {w.link && (
        <a href={w.link.href} target={w.link.href.startsWith('/') ? undefined : '_blank'} rel="noopener" class="mt-4 inline-block font-mono text-sm text-[--color-accent] hover:underline">{w.link.label} →</a>
      )}
    </article>
  ))}
</div>

<style>
  /* Rich logos keep inner detail at rest (greyscale + lifted brightness) and bloom to full
     colour on hover; flat/monochrome logos render as a light silhouette and brighten on hover. */
  .tech-icon {
    opacity: 0.9;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .tech-icon.is-rich {
    filter: grayscale(1) brightness(1.4);
  }
  .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.72);
  }
  .group\/tech:hover .tech-icon {
    opacity: 1;
  }
  .group\/tech:hover .tech-icon.is-rich {
    filter: none;
  }
  .group\/tech:hover .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.92);
  }

  /* The chip is absolutely positioned, so the name expands over its neighbours on hover
     instead of reflowing the row (which would wrap the hovered item out from under the cursor). */
  .tech-chip {
    z-index: 1;
    background-color: var(--color-surface);
    transition: border-color 0.2s ease;
  }
  .group\/tech:hover .tech-chip {
    z-index: 10;
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    box-shadow: 0 4px 14px -4px rgb(0 0 0 / 0.6);
  }
  .tech-name {
    transition: max-width 0.24s ease, opacity 0.22s ease, padding 0.24s ease;
  }
  .group\/tech:hover .tech-name {
    max-width: 11rem;
    opacity: 1;
    padding: 0 0.5rem 0 0.25rem;
  }

  /* Staggered reveal once the entry scrolls into view. */
  .tech {
    opacity: 0;
    transform: translateY(8px);
  }
  .tech-pool.in-view .tech {
    opacity: 1;
    transform: none;
    transition: opacity 0.45s ease var(--d), transform 0.45s ease var(--d);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech { opacity: 1; transform: none; }
    .tech-pool.in-view .tech { transition: none; }
    .tech-name { transition: opacity 0.15s ease; }
  }
</style>

<script>
  const pools = document.querySelectorAll('.tech-pool');
  if (pools.length) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.2 });
    pools.forEach((p) => io.observe(p));
  }
</script>
