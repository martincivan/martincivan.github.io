---
import { Icon } from 'astro-icon/components';
import type { Lang } from '../i18n/utils';
import { getWork, statusLabel } from '../data/localized';
import { techIcons, iconTone } from '../data/techIcons';

interface Props { lang: Lang }
const { lang } = Astro.props;
const work = getWork(lang);

// Status is the one place colour carries meaning: green = live, blue = delivered,
// amber = wound down, neutral = prototype. Everything else uses the brand indigo.
// Functional status colours, kept distinct from the amber brand accent so amber
// stays unique to the brand: green = live, blue = delivered, slate = wound down,
// neutral = prototype.
const statusColor: Record<string, string> = {
  current: '#4ade80',
  shipped: '#60a5fa',
  sunset: '#9ca3af',
  unlaunched: '#e8920c',
  demo: '#8b867c',
};
---
<div class="space-y-4">
  {work.map((w) => (
    <article
      class:list={['work-card card group/work relative overflow-hidden p-5 sm:p-6', w.featured && 'card-accent']}
    >
      {/* faint brand-hue corner glow, revealed on hover */}
      <span class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full opacity-0 blur-2xl transition-opacity duration-300 group-hover/work:opacity-100" style="background: radial-gradient(circle, color-mix(in oklab, var(--color-accent) 28%, transparent), transparent 70%)" aria-hidden="true"></span>

      <div class="relative flex items-start gap-4">
        {w.logo ? (
          <span class="mark flex h-11 w-11 shrink-0 items-center justify-center">
            <img src={w.logo} alt={`${w.name} logo`} class="max-h-full max-w-full object-contain" loading="lazy" decoding="async" />
          </span>
        ) : w.icon ? (
          <span class="mark flex h-11 w-11 shrink-0 items-center justify-center text-accent" aria-hidden="true">
            <Icon name={w.icon} class="h-7 w-7" />
          </span>
        ) : null}
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-lg font-semibold tracking-tight">
              {w.href ? (
                <a href={w.href} target="_blank" rel="noopener" class="transition-colors hover:text-accent">{w.name}</a>
              ) : w.name}
            </h3>
            <div class="flex items-center gap-2">
              {w.status && (
                <span
                  class="rounded-full border px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide"
                  style={`color:${statusColor[w.status]}; border-color:color-mix(in oklab, ${statusColor[w.status]} 35%, var(--color-border)); background:color-mix(in oklab, ${statusColor[w.status]} 9%, transparent)`}
                >{statusLabel[lang][w.status]}</span>
              )}
              <span class="font-mono text-xs text-faint">{w.period}</span>
            </div>
          </div>
          <p class="mt-1 font-mono text-xs font-medium text-accent">{w.kind}</p>
        </div>
      </div>

      <p class="relative mt-3 max-w-3xl text-sm leading-relaxed text-muted">{w.summary}</p>

      {w.feature && (
        <a
          href={w.feature.href}
          target="_blank"
          rel="noopener"
          class="feature-quote group/feat relative mt-4 flex items-center gap-3.5 rounded-lg border border-border bg-bg-soft/60 px-4 py-3 transition-colors hover:border-accent/40"
        >
          <img src="/logos/forbes.svg" alt={w.feature.source} class="h-4 w-auto shrink-0 opacity-90" loading="lazy" decoding="async" />
          <span class="h-7 w-px shrink-0 bg-border" aria-hidden="true"></span>
          <span class="text-sm italic leading-snug text-fg">“{w.feature.quote}”</span>
          <Icon name="lucide:arrow-up-right" class="ml-auto h-4 w-4 shrink-0 text-faint transition-colors group-hover/feat:text-accent" />
        </a>
      )}

      <ul class="tech-pool relative mt-4 flex flex-wrap items-center gap-2">
        {w.stack.map((s, si) => (
          techIcons[s] ? (
            <li class="tech group/tech relative h-7 w-7" style={`--d:${si * 45}ms`}>
              <span class="tech-chip absolute left-0 top-0 inline-flex h-7 items-center overflow-hidden rounded-md border border-border">
                <span class:list={["tech-icon flex h-7 w-7 shrink-0 items-center justify-center", `is-${iconTone(techIcons[s])}`]}>
                  <Icon name={techIcons[s]} class="h-[18px] w-[18px]" />
                </span>
                <span class="tech-name max-w-0 whitespace-nowrap font-mono text-[11px] text-fg opacity-0">{s}</span>
              </span>
            </li>
          ) : (
            <li class="tech inline-flex h-7 items-center rounded-md border border-border px-2 font-mono text-[11px] text-faint" style={`--d:${si * 45}ms`}>{s}</li>
          )
        ))}
      </ul>

      {w.link && (
        <a href={w.link.href} target={w.link.href.startsWith('/') ? undefined : '_blank'} rel="noopener" class="relative mt-4 inline-flex items-center gap-1 font-mono text-sm text-accent hover:underline">{w.link.label} <span aria-hidden="true">→</span></a>
      )}
    </article>
  ))}
</div>

<style>
  /* All work cards share the brand hue for highlights — colour only means
     something on the status badge. */
  .work-card {
    --p: var(--color-accent);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .work-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--p) 45%, var(--color-border));
    box-shadow: 0 12px 30px -16px color-mix(in oklab, var(--p) 60%, #000);
  }

  /* Brand logos sit directly on the dark card in their natural colours (no tile),
     each normalised to a consistent square slot. Lifted slightly so darker marks
     stay legible, and brightened on hover. */
  .mark img {
    filter: brightness(1.06);
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  .work-card:hover .mark img {
    filter: brightness(1.18);
    transform: scale(1.04);
  }

  /* Rich logos keep inner detail at rest (greyscale + lifted brightness) and bloom to full
     colour on hover; flat/monochrome logos render as a light silhouette and brighten on hover. */
  .tech-icon {
    opacity: 0.9;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .tech-icon.is-rich {
    filter: grayscale(1) brightness(1.4);
  }
  .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.72);
  }
  .group\/tech:hover .tech-icon {
    opacity: 1;
  }
  .group\/tech:hover .tech-icon.is-rich {
    filter: none;
  }
  .group\/tech:hover .tech-icon.is-flat {
    filter: grayscale(1) brightness(0) invert(0.92);
  }

  /* The chip is absolutely positioned, so the name expands over its neighbours on hover
     instead of reflowing the row (which would wrap the hovered item out from under the cursor). */
  .tech-chip {
    z-index: 1;
    background-color: var(--color-surface);
    transition: border-color 0.2s ease;
  }
  .group\/tech:hover .tech-chip {
    z-index: 10;
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    box-shadow: 0 4px 14px -4px rgb(0 0 0 / 0.6);
  }
  .tech-name {
    transition: max-width 0.24s ease, opacity 0.22s ease, padding 0.24s ease;
  }
  .group\/tech:hover .tech-name {
    max-width: 11rem;
    opacity: 1;
    padding: 0 0.5rem 0 0.25rem;
  }

  /* Staggered reveal once the entry scrolls into view. */
  .tech {
    opacity: 0;
    transform: translateY(8px);
  }
  .tech-pool.in-view .tech {
    opacity: 1;
    transform: none;
    transition: opacity 0.45s ease var(--d), transform 0.45s ease var(--d);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech { opacity: 1; transform: none; }
    .tech-pool.in-view .tech { transition: none; }
    .tech-name { transition: opacity 0.15s ease; }
    .work-card:hover { transform: none; }
  }
</style>

<script>
  const pools = document.querySelectorAll('.tech-pool');
  if (pools.length) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.2 });
    pools.forEach((p) => io.observe(p));
  }
</script>
