---
// MC monogram — gradient squircle with knocked-out letterforms.
interface Props { size?: number; knockout?: string; class?: string }
const { size = 30, knockout = '#08080a', class: cls } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 100" class={cls} aria-hidden="true" role="img">
  <defs>
    <linearGradient id="mc-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#818cf8" />
      <stop offset="1" stop-color="#c084fc" />
    </linearGradient>
  </defs>
  <rect x="4" y="4" width="92" height="92" rx="27" fill="url(#mc-grad)" />
  <path d="M25 69 V35 L42 55 L59 35 V69" fill="none" stroke={knockout} stroke-width="9" stroke-linecap="round" stroke-linejoin="round" />
  <path d="M80 43 A14.5 14.5 0 1 0 80 57" fill="none" stroke={knockout} stroke-width="9" stroke-linecap="round" />
</svg>
