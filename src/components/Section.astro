---
interface Props {
  id?: string;
  index?: string;
  eyebrow: string;
  title: string;
  lead?: string;
  first?: boolean;
}
const { id, index, eyebrow, title, lead, first } = Astro.props;
---
<section
  id={id}
  class:list={['scroll-mt-24 py-16 sm:py-24', { 'border-t border-[--color-border]': !first }]}
>
  <header class="mb-10 max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-[--color-accent]">
      {index && <span class="text-[--color-faint]">{index} · </span>}{eyebrow}
    </p>
    <h2 class="mt-2.5 text-2xl font-semibold tracking-tight sm:text-[2rem]">{title}</h2>
    {lead && <p class="mt-3 leading-relaxed text-[--color-muted]">{lead}</p>}
  </header>
  <slot />
</section>
