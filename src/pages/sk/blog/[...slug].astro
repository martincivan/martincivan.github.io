---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import PostView from '../../../components/PostView.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.data.lang === 'sk');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
---
<Base lang="sk" title={`${post.data.title} — Martin Civáň`} description={post.data.description}>
  <PostView post={post} lang="sk" />
</Base>
