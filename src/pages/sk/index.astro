---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/ui';
import HomeView from '../../components/HomeView.astro';
import Section from '../../components/Section.astro';
import AboutIntro from '../../components/AboutIntro.astro';
import WorkTimeline from '../../components/WorkTimeline.astro';
import SkillsGrid from '../../components/SkillsGrid.astro';
import Contact from '../../components/Contact.astro';

const lang = 'sk' as const;
const s = useTranslations(lang).sections;
const t = useTranslations(lang);
---
<Base lang={lang} title="Martin Civáň — inžinier pre platformy, softvér a AI" description="Inžinier naprieč platformami, softvérom a aplikovanou AI — stavia cloud-native základ pod slovenským e-Governmentom. Kubernetes, GitOps, infrastructure-as-code a AI.">
  <HomeView lang={lang} />
  <Section id="about" index="01" eyebrow={s.about.eyebrow} title={s.about.title}>
    <AboutIntro lang={lang} />
  </Section>
  <Section id="projects" index="02" eyebrow={s.projects.eyebrow} title={s.projects.title} lead={t.projects.intro}>
    <WorkTimeline lang={lang} />
  </Section>
  <Section id="skills" index="03" eyebrow={s.skills.eyebrow} title={s.skills.title} lead={s.skills.lead}>
    <SkillsGrid lang={lang} />
  </Section>
  <Section id="contact" eyebrow={s.contact.eyebrow} title={s.contact.title} lead={s.contact.lead}>
    <Contact />
  </Section>
</Base>
