---
import Base from '../layouts/Base.astro';
---
<Base lang="en" title="404 — Martin Civáň" description="Page not found.">
  <section class="flex min-h-[70vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-mono text-6xl font-semibold text-[--color-accent]">404</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">This page took a different route.</h1>
    <p class="mt-3 max-w-md text-[--color-muted]">
      The thing you’re after isn’t here — maybe it moved, maybe it never existed. Let’s get you back on track.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-lg bg-[--color-accent-strong] px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[--color-accent]">Home</a>
      <a href="/#projects" class="rounded-lg border border-[--color-border] px-5 py-2.5 text-sm font-medium transition-colors hover:bg-[--color-surface]">Projects</a>
    </div>
  </section>
</Base>
